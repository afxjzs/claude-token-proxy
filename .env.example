# Path to Claude CLI credentials file
# Default: ~/.claude/.credentials.json
CREDENTIALS_PATH=~/.claude/.credentials.json

# Port for the proxy server
PORT=3456

# Optional shared secret for bearer token auth
# If set, clients must send Authorization: Bearer <this-value>
PROXY_API_KEY=

# How many seconds before expiry to refresh (default: 600 = 10 min)
REFRESH_MARGIN_SECONDS=600

# How often to check token expiry in seconds (default: 60)
CHECK_INTERVAL_SECONDS=60
